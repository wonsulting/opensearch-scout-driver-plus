{
    "name": "wonsulting/opensearch-scout-driver-plus",
    "description": "Extension for OpenSearch Scout Driver",
    "keywords": [
        "scout",
        "opensearch",
        "laravel",
        "driver",
        "php"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ivan Babenko",
            "email": "babenko.i.a@gmail.com"
        },
        {
            "name": "Friends Of CAT"
        },
        {
            "name": "Wonsulting",
            "homepage": "https://wonsulting.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "OpenSearch\\ScoutDriverPlus\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenSearch\\ScoutDriverPlus\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/scout": "^10.0 || ^11.0",
        "wonsulting/opensearch-scout-driver": "^2.1 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0",
        "orchestra/testbench": "^9.14 || ^10.6 || ^11.0",
        "wonsulting/opensearch-migrations": "^2.0 || ^3.0",
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1"
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenSearch\\ScoutDriverPlus\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "check-style": "./vendor/bin/php-cs-fixer fix --allow-risky=yes --dry-run --diff --show-progress=dots --verbose",
        "fix-style": "./vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "analyse": "./vendor/bin/phpstan analyse",
        "test": "./vendor/bin/phpunit --testdox",
        "test-coverage": "./vendor/bin/phpunit --testdox --coverage-text"
    }
}
